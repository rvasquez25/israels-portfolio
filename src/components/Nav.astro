---
const links = [
  { href: '#about', label: 'About' },
  { href: '#lessons', label: 'Lessons' },
  { href: '#rates', label: 'Rates' },
  { href: '#gallery', label: 'Gallery' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="fixed top-0 inset-x-0 z-50 border-b border-white/5 bg-base/85 backdrop-blur-md">
  <nav class="mx-auto max-w-6xl px-5 h-16 flex items-center justify-between">
    <a href="#top" class="font-display text-lg font-bold tracking-wide text-ink">
      Israel Vasquez
    </a>

    <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-muted">
      {
        links.map((l) => (
          <li>
            <a href={l.href} class="transition-colors hover:text-accent-soft">
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href="#contact"
      class="hidden sm:inline-flex items-center rounded-full border border-gold/60 px-4 py-1.5 text-sm font-semibold text-gold-soft transition-colors hover:bg-gold hover:text-base"
    >
      Book a Lesson
    </a>

    <!-- Mobile menu via native <details> — no JS required -->
    <details class="md:hidden relative">
      <summary class="list-none cursor-pointer p-2 text-ink [&::-webkit-details-marker]:hidden">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </summary>
      <ul class="absolute right-0 mt-2 w-44 rounded-xl border border-white/10 bg-elevated p-2 shadow-xl">
        {
          [...links, { href: '#contact', label: 'Book a Lesson' }].map((l) => (
            <li>
              <a href={l.href} class="block rounded-lg px-3 py-2 text-sm text-muted hover:bg-navy-deep hover:text-ink">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </details>
  </nav>
</header>
