---
import site from '../data/site.json';
import lessons from '../data/lessons.json';
---

<section id="contact" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-5">
    <div class="grid gap-12 md:grid-cols-2">
      <!-- Intro + direct contact -->
      <div class="text-scrim">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-accent">
          Get in touch
        </p>
        <h2 class="mt-2 font-display text-3xl font-bold text-ink sm:text-4xl">
          Contact Me
        </h2>
        <p class="mt-4 max-w-md text-muted leading-relaxed">
          Ready to start, or have a question about lessons? Send a message and
          I'll get back to you. You can also reach me directly:
        </p>

        <div class="mt-8 space-y-4">
          <a href={`tel:${site.phoneHref}`} class="flex items-center gap-4 group">
            <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-navy-deep text-accent transition-colors group-hover:bg-accent group-hover:text-base">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
            </span>
            <span>
              <span class="block text-xs uppercase tracking-wider text-muted">Cell</span>
              <span class="font-semibold text-ink">{site.phone}</span>
            </span>
          </a>

          <a href={site.instagramUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group">
            <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-navy-deep text-accent transition-colors group-hover:bg-accent group-hover:text-base">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" /><circle cx="12" cy="12" r="4" /><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" /></svg>
            </span>
            <span>
              <span class="block text-xs uppercase tracking-wider text-muted">Instagram</span>
              <span class="font-semibold text-ink">@{site.instagram}</span>
            </span>
          </a>
        </div>
      </div>

      <!-- Netlify form. data-netlify="true" lets Netlify capture submissions
           from the statically built HTML — no backend needed. The honeypot
           field silently traps bots. -->
      <form
        name="lesson-inquiry"
        method="POST"
        action="/thank-you"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="rounded-2xl border border-white/10 bg-elevated/95 p-6 sm:p-8"
      >
        <input type="hidden" name="form-name" value="lesson-inquiry" />
        <p class="hidden">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div class="grid gap-5">
          <div>
            <label for="name" class="mb-1.5 block text-sm font-medium text-ink">Name</label>
            <input id="name" name="name" type="text" required
              class="w-full rounded-lg border border-white/10 bg-base px-4 py-2.5 text-ink placeholder:text-muted/60 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              placeholder="Your name" />
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="email" class="mb-1.5 block text-sm font-medium text-ink">Email</label>
              <input id="email" name="email" type="email" required
                class="w-full rounded-lg border border-white/10 bg-base px-4 py-2.5 text-ink placeholder:text-muted/60 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                placeholder="you@email.com" />
            </div>
            <div>
              <label for="phone" class="mb-1.5 block text-sm font-medium text-ink">Phone <span class="text-muted">(optional)</span></label>
              <input id="phone" name="phone" type="tel"
                class="w-full rounded-lg border border-white/10 bg-base px-4 py-2.5 text-ink placeholder:text-muted/60 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                placeholder="(915) 000-0000" />
            </div>
          </div>

          <div>
            <label for="instrument" class="mb-1.5 block text-sm font-medium text-ink">Interested in</label>
            <select id="instrument" name="instrument"
              class="w-full rounded-lg border border-white/10 bg-base px-4 py-2.5 text-ink focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent">
              {lessons.offerings.map((o) => <option value={o.title}>{o.title}</option>)}
              <option value="Not sure yet">Not sure yet</option>
            </select>
          </div>

          <div>
            <label for="message" class="mb-1.5 block text-sm font-medium text-ink">Message</label>
            <textarea id="message" name="message" rows="4" required
              class="w-full rounded-lg border border-white/10 bg-base px-4 py-2.5 text-ink placeholder:text-muted/60 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              placeholder="Tell me about your experience level and goals..."></textarea>
          </div>

          <button type="submit"
            class="inline-flex items-center justify-center rounded-full bg-accent px-7 py-3 font-semibold text-base transition-colors hover:bg-accent-soft">
            Send Message
          </button>
        </div>
      </form>
    </div>
  </div>
</section>
