---
import lessons from '../data/lessons.json';
import Icon from './Icon.astro';
---

<section id="lessons" class="bg-elevated/40 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-5">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-accent">
        Music Lessons
      </p>
      <h2 class="mt-2 font-display text-3xl font-bold text-ink sm:text-4xl">
        {lessons.heading}
      </h2>
      <p class="mt-4 text-muted">{lessons.subheading}</p>
      <div class="divider-gem mt-6">◆</div>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        lessons.offerings.map((o) => (
          <article class="group rounded-2xl border border-white/10 bg-base/60 p-6 transition-colors hover:border-accent/40">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-navy-deep text-accent transition-colors group-hover:bg-accent group-hover:text-base">
              <Icon name={o.icon} />
            </div>
            <h3 class="mt-5 font-display text-xl font-semibold text-ink">{o.title}</h3>
            <p class="mt-1 text-xs font-semibold uppercase tracking-wider text-gold-soft">
              {o.level}
            </p>
            <p class="mt-3 text-sm leading-relaxed text-muted">{o.description}</p>
          </article>
        ))
      }

      <!-- Perks card fills the grid's last cell -->
      <article class="rounded-2xl border border-gold/30 bg-gradient-to-br from-navy-deep/60 to-base p-6">
        <h3 class="font-display text-xl font-semibold text-ink">Every Lesson Includes</h3>
        <ul class="mt-4 space-y-3">
          {
            lessons.perks.map((perk) => (
              <li class="flex items-start gap-2.5 text-sm text-muted">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6 9 17l-5-5" />
                </svg>
                {perk}
              </li>
            ))
          }
        </ul>
      </article>
    </div>
  </div>
</section>
