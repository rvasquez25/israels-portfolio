---
import about from '../data/about.json';
---

<section id="about" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-5">
    <div class="grid items-center gap-12 md:grid-cols-5">
      <!-- Photo -->
      <div class="order-2 md:order-1 md:col-span-2">
        <div class="rounded-2xl border border-white/10 p-1.5">
          <div class="aspect-[4/5] overflow-hidden rounded-xl bg-gradient-to-br from-navy-mid/40 to-elevated">
            <img
              src={about.photo}
              alt={about.photoAlt}
              class="h-full w-full object-cover"
              loading="lazy"
              onerror="this.style.display='none'"
            />
          </div>
        </div>
      </div>

      <!-- Copy -->
      <div class="order-1 md:order-2 md:col-span-3">
        <h2 class="font-display text-3xl font-bold text-ink sm:text-4xl">
          {about.heading}
        </h2>
        <div class="mt-3 h-1 w-16 rounded-full bg-gold"></div>

        <div class="mt-6 space-y-4 text-muted leading-relaxed">
          {about.paragraphs.map((p) => <p>{p}</p>)}
        </div>

        <ul class="mt-8 flex flex-wrap gap-2.5">
          {
            about.credentials.map((c) => (
              <li class="rounded-full border border-accent/30 bg-accent/10 px-3.5 py-1.5 text-sm text-accent-soft">
                {c}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
