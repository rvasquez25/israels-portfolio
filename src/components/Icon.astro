---
// Lightweight inline icon set for the lesson disciplines. Keeps things
// dependency-free; stroke uses currentColor so color is controlled by the
// parent's text color.
interface Props {
  name: string;
  class?: string;
}
const { name, class: className = 'w-8 h-8' } = Astro.props;
---

{
  name === 'piano' && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="4" width="18" height="16" rx="2" />
      <path d="M7 4v9M11 4v9M15 4v9M19 4v9M3 13h18" />
    </svg>
  )
}
{
  name === 'snare' && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <ellipse cx="12" cy="8" rx="9" ry="3" />
      <path d="M3 8v6c0 1.7 4 3 9 3s9-1.3 9-3V8" />
      <path d="M16 3l4 8M19 3l-3 8" />
    </svg>
  )
}
{
  name === 'marimba' && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 14c3-7 15-7 18 0" />
      <path d="M6 12.5V17M10 10.5V18M14 10.5V18M18 12.5V17" />
    </svg>
  )
}
{
  name === 'congas' && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6 5h5l-1 13a1.5 1.5 0 0 1-3 0z" />
      <path d="M14 7h5l-1 11a1.5 1.5 0 0 1-3 0z" />
      <ellipse cx="8.5" cy="5" rx="2.5" ry="1" />
      <ellipse cx="16.5" cy="7" rx="2.5" ry="1" />
    </svg>
  )
}
{
  name === 'drumset' && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <ellipse cx="12" cy="15" rx="7" ry="3" />
      <path d="M5 15v3c0 1.1 3.1 2 7 2s7-.9 7-2v-3" />
      <path d="M3 9h6M18 5l3 2" />
      <circle cx="20" cy="8" r="0.5" />
    </svg>
  )
}
